# Build-Artefakte — NIE committen (Vercel baut selbst; committetes dist verursacht stale Bundles)
dist/
dist-ssr/

# Dependencies
node_modules/

# Supabase CLI local cache (created by `supabase link`) — not project source
supabase/.temp/
supabase/.branches/

# Lokale Env-Overrides (NICHT .env.production — die ist bewusst committet mit dem öffentlichen anon key)
.env
.env.local
.env.*.local
*.local

# Logs / Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# Throwaway local scripts (e.g. E2E seed using a service-role key — never commit)
scripts/seed-e2e.mjs

# Local-only throwaway brand assets (not deployed; kept on disk for reference)
public/brand-arrival-germany.html
public/logo.png

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
