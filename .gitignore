# Build-Artefakte — NIE committen (Vercel baut selbst; committetes dist verursacht stale Bundles)
dist/
dist-ssr/

# Dependencies
node_modules/

# Lokale Env-Overrides (NICHT .env.production — die ist bewusst committet mit dem öffentlichen anon key)
.env
.env.local
.env.*.local
*.local

# Logs / Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# Throwaway local scripts (e.g. E2E seed using a service-role key — never commit)
scripts/seed-e2e.mjs

# Editor / OS
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
