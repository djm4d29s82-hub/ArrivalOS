# Production-Konfiguration — vor Deploy ausfüllen
# Kopie als .env.production speichern, dann `vite build`

# === Company / Impressum ===
VITE_COMPANY_LEGAL_NAME="NeuLand Welcome Services GmbH"
VITE_COMPANY_BRAND="ArrivalOS by NeuLand"
VITE_COMPANY_STREET=""
VITE_COMPANY_ZIP=""
VITE_COMPANY_CITY=""
VITE_COMPANY_COUNTRY="Deutschland"
VITE_COMPANY_PHONE=""
VITE_COMPANY_EMAIL=""
VITE_COMPANY_PRESS_EMAIL=""
VITE_COMPANY_DPO_EMAIL=""
VITE_COMPANY_CAREERS_EMAIL=""
VITE_COMPANY_CEO=""
VITE_COMPANY_HRB=""
VITE_COMPANY_REGISTER_COURT=""
VITE_COMPANY_VAT_ID=""
VITE_HOSTING_CITY="Frankfurt am Main"
# Rechnungs-Pflichtangaben (§14 UStG). Kleinunternehmer §19 → Steuernummer statt USt-IdNr.
VITE_COMPANY_TAX_NUMBER=""
VITE_COMPANY_IBAN=""
VITE_COMPANY_BANK=""

# === Site ===
VITE_SITE_URL="https://arrivalos.neuland.de"

# === Features ===
# Webhook-URL für Lead-Submissions (z.B. Resend, Zapier, Make, eigener API-Endpoint)
VITE_LEAD_WEBHOOK_URL=""

# Plausible-Domain (leer = kein Tracking). Cookieless, DSGVO-konform.
VITE_PLAUSIBLE_DOMAIN=""

# === Backend (Supabase) ===
# Beide Variablen leer = localStorage-Modus (Demo).
# Beide gesetzt = Supabase wird automatisch verwendet (Produktion).
#
# Setup:
#   1. Supabase-Projekt anlegen (https://app.supabase.com)
#   2. SQL Editor → supabase/schema.sql ausführen
#   3. Optional: supabase/seed.sql für Demo-Daten
#   4. Settings → API: URL + anon key kopieren
#   5. Storage → Bucket "documents" anlegen (privat)
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# === Error-Tracking (Sentry) ===
# Sentry-DSN aus https://sentry.io → Projekt → Client Keys
# Maskiert automatisch Inputs/Texts (DSGVO-konform)
VITE_SENTRY_DSN=""
VITE_SENTRY_ENV="production"
